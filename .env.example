# =============================================================================
# La Mega Polla Mundialista — variables de entorno
# =============================================================================
#
# LOCAL:
#   cp .env.example .env.local
#   Rellena los valores desde Supabase Dashboard (ver abajo).
#
# VERCEL (https://vercel.com → la-mega-polla-mundialista → Settings → Environment Variables):
#   Crea cada variable abajo en Production Y Preview.
#   - NEXT_PUBLIC_* → puede ir a "All Environments"
#   - SUPABASE_SERVICE_ROLE_KEY → Production + Preview, SIN "Expose to Browser"
#   Tras guardar: Redeploy obligatorio (las NEXT_PUBLIC_* se embeben en el build).
#   Si ves MIDDLEWARE_INVOCATION_FAILED, casi siempre falta redeploy o el nombre de la variable está mal.
#
# Dónde copiar los valores en Supabase:
#   https://supabase.com/dashboard/project/cygdbtmqtbscmxjvlmff/settings/api
#   - Project URL  → NEXT_PUBLIC_SUPABASE_URL
#   - anon public  → NEXT_PUBLIC_SUPABASE_ANON_KEY
#   - service_role → SUPABASE_SERVICE_ROLE_KEY (secreto; solo servidor)
#
# =============================================================================

# --- Supabase (obligatorias) ---

NEXT_PUBLIC_SUPABASE_URL=https://cygdbtmqtbscmxjvlmff.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=peg_aqui_tu_anon_key_jwt_o_publishable

# Solo servidor (admin, generar códigos de invitación). Nunca en el cliente.
SUPABASE_SERVICE_ROLE_KEY=peg_aqui_tu_service_role_key

# Grupo de WhatsApp (solo participantes registrados ven el enlace en Inicio / tabla).
# WHATSAPP_GROUP_INVITE_URL=https://chat.whatsapp.com/EYsnqvZN29X1cMwFTGSMJx

# --- Opcional (CLI local) ---

# SUPABASE_PROJECT_REF=cygdbtmqtbscmxjvlmff

# =============================================================================
# Supabase Auth (Dashboard → Authentication)
#
# - Providers → Email: ON
# - Confirm email: OFF (recomendado para registro directo en /join)
# - Redirect URLs (solo si usas confirmación por correo):
#     http://localhost:3000/auth/callback
#     https://la-mega-polla-mundialista.vercel.app/auth/callback
# Site URL: https://la-mega-polla-mundialista.vercel.app
# =============================================================================
